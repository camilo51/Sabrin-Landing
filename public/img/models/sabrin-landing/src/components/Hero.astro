---
---

<section class="paper-texture relative overflow-hidden border-b border-line/70">
  <div class="mx-auto grid max-w-7xl gap-16 px-6 py-20 lg:grid-cols-[1.1fr_0.9fr] lg:items-center lg:px-10 lg:py-28">
    <div>
      <p class="eyebrow text-xs font-medium text-seal">
        Software jurídico · Derechos de Petición y gestión de expedientes
      </p>

      <h1 class="mt-6 font-display text-[2.6rem] leading-[1.05] tracking-tight text-ink sm:text-5xl lg:text-[3.4rem]">
        Ningún término legal se vence en una <span class="italic text-seal">hoja de Excel</span>.
      </h1>

      <p class="mt-6 max-w-xl text-balance font-body text-lg leading-relaxed text-ink-soft">
        SABRIN centraliza tus clientes, expedientes y Derechos de Petición en un solo lugar,
        controla automáticamente los términos legales y redacta documentos jurídicos con IA
        en minutos, no en horas.
      </p>

      <div class="mt-9 flex flex-col gap-4 sm:flex-row sm:items-center">
        <a
          href="#demo"
          class="inline-flex items-center justify-center gap-2 bg-ink px-7 py-3.5 font-body text-base font-semibold text-paper shadow-stamp transition-colors hover:bg-seal"
        >
          Solicitar una demostración
        </a>
        <a
          href="#producto"
          class="underline-grow inline-flex items-center justify-center gap-2 px-2 py-3.5 font-body text-base font-medium text-ink-soft hover:text-ink"
        >
          Ver cómo funciona →
        </a>
      </div>

      <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-3 border-t border-line/70 pt-7">
        <p class="font-body text-sm text-ink-soft">
          Diseñado para abogados independientes y pequeñas firmas en Colombia
        </p>
      </div>
    </div>

    <!-- Signature element: folio de expediente con seguimiento de término legal -->
    <div class="relative mx-auto w-full max-w-md lg:mx-0">
      <div class="folio relative -rotate-1 p-6 sm:p-7">
        <div class="flex items-start justify-between gap-4 border-b border-line pb-4">
          <div>
            <p class="eyebrow text-[11px] text-ink-soft">Expediente</p>
            <p class="mt-1 font-display text-lg font-semibold text-ink">DP-2026-0341</p>
          </div>
          <span class="stamp h-14 w-14 shrink-0 text-seal">
            <span class="text-center font-mono text-[10px] font-medium leading-tight">
              8 días<br />hábiles
            </span>
          </span>
        </div>

        <dl class="mt-4 space-y-3 font-body text-sm">
          <div class="flex items-center justify-between">
            <dt class="text-ink-soft">Cliente</dt>
            <dd class="font-medium text-ink">María Fernanda Ríos</dd>
          </div>
          <div class="flex items-center justify-between">
            <dt class="text-ink-soft">Tipo de proceso</dt>
            <dd class="font-medium text-ink">Derecho de Petición</dd>
          </div>
          <div class="flex items-center justify-between">
            <dt class="text-ink-soft">Vence</dt>
            <dd class="font-medium text-seal-deep">25 de junio, 2026</dd>
          </div>
          <div class="flex items-center justify-between">
            <dt class="text-ink-soft">Estado</dt>
            <dd>
              <span class="inline-flex items-center gap-1.5 bg-navy/10 px-2.5 py-1 text-xs font-semibold text-navy">
                <span class="h-1.5 w-1.5 rounded-full bg-navy"></span>
                En redacción · IA
              </span>
            </dd>
          </div>
        </dl>

        <div class="mt-5 border-t border-line pt-4">
          <div class="flex items-center justify-between font-mono text-[11px] text-ink-soft">
            <span>Honorarios</span>
            <span class="font-semibold text-ink">$1.200.000 COP</span>
          </div>
          <div class="mt-2 h-1.5 w-full bg-paper-deep">
            <div class="h-1.5 w-2/3 bg-gold"></div>
          </div>
          <p class="mt-1.5 font-mono text-[11px] text-ink-soft">66% pagado</p>
        </div>
      </div>

      <!-- Tarjeta secundaria asomando detrás -->
      <div class="folio absolute -right-4 -top-5 -z-10 hidden h-full w-full rotate-3 sm:block" aria-hidden="true"></div>
    </div>
  </div>
</section>
