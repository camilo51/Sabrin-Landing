---
const links = [
  { href: "#propuesta", label: "Qué resolvemos" },
  { href: "#producto", label: "Producto" },
  { href: "#confianza", label: "Firmas que confían" },
  { href: "#precios", label: "Planes" },
  { href: "#faq", label: "Preguntas" },
];
---

<header class="sticky top-0 z-50 border-b border-line/70 bg-paper/85 backdrop-blur-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-10">
    <a href="#" class="flex items-center gap-2.5">
      <span class="stamp h-9 w-9 text-navy">
        <span class="font-display text-base">S</span>
      </span>
      <span class="font-display text-xl font-semibold tracking-tight text-ink">SABRIN</span>
    </a>

    <nav class="hidden items-center gap-8 lg:flex">
      {links.map((link) => (
        <a
          href={link.href}
          class="underline-grow font-body text-[15px] text-ink-soft transition-colors hover:text-ink"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="#demo"
        class="inline-flex items-center gap-2 bg-ink px-5 py-2.5 font-body text-sm font-semibold text-paper transition-colors hover:bg-seal"
      >
        Solicitar demo
      </a>
    </div>
  </div>
</header>
