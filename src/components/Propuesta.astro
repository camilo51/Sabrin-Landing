---
const pilares = [
  {
    icono: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
    titulo: "Términos bajo control",
    resumen: "Vigila los días hábiles de cada caso y avisa antes de que venza.",
  },
  {
    icono: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`,
    titulo: "IA que redacta por ti",
    resumen: "Genera borradores jurídicos a partir de los hechos del caso.",
  },
  {
    icono: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`,
    titulo: "Todo en un expediente",
    resumen: "Clientes, documentos y evidencias en un solo lugar.",
  },
];
---

<section id="propuesta" class="border-b border-line/70 bg-paper-deep/40">
  <div class="mx-auto max-w-7xl px-6 py-20 lg:px-10 lg:py-24">
    <div class="max-w-xl">
      <p class="eyebrow text-xs font-medium text-seal">Por qué existe SABRIN</p>
      <h2 class="mt-4 font-display text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
        El expediente jurídico no debería vivir en cinco lugares distintos.
      </h2>
    </div>

    <div class="mt-14 grid gap-8 border-t border-line/70 pt-12 lg:grid-cols-3">
      {pilares.map((p) => (
        <div class="flex gap-4">
          <span class="mt-1 shrink-0 text-seal" set:html={p.icono} />
          <div>
            <h3 class="font-display text-lg font-semibold text-ink">{p.titulo}</h3>
            <p class="mt-1.5 font-body text-sm leading-relaxed text-ink-soft">{p.resumen}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>